{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "bodyParser": false,
        "includeFiles": [
          "*.html",
          "*.css",
          "*.js",
          "img/**",
          "data/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
