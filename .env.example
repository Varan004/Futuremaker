# Copy this file to .env and fill in your values

# MongoDB Atlas connection string (required for Vercel deployment)
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Admin panel password
ADMIN_PASSWORD=futuremakers-admin

# Session signing secrets (use long random strings in production)
ADMIN_SESSION_SECRET=
TEAM_SESSION_SECRET=

# Set to "production" on Vercel (enables secure cookies)
NODE_ENV=production
